{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/repo-layout-check.js",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/run-node-hook.ps1 -Script .github/hooks/scripts/repo-layout-check.js -FallbackMode deny",
        "timeout": 10
      }
    ]
  }
}
