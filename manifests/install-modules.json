      "requiresSecrets": false,
      "targets": {
        "copilot": {
          "status": "full",
          "targetPaths": [".github/copilot-instructions.md", ".github/instructions", ".github/prompts"],
          "operations": [
            { "type": "copy", "from": "plugins/copilot/templates/copilot-instructions.md", "to": ".github/copilot-instructions.md" },
            { "type": "copy", "from": ".github/instructions", "to": ".github/instructions" },
            { "type": "copy", "from": ".github/prompts", "to": ".github/prompts" }
          ]
        }
