{
  "version": 1,
  "modules": [
    {
      "id": "module:skills-core-generated",
      "kind": "generated",
      "description": "Generated skill payloads for the core workflow skills.",
      "sourcePaths": [
        "skills/plan-product/**",
        "skills/plan-architecture/**",
        "skills/investigate/**",
        "skills/review/**",
        "skills/security-review/**",
