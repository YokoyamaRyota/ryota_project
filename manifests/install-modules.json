      "generatedPaths": [".github/skills/**"],
      "riskLevel": "low",
      "requiresSecrets": false,
      "targets": {
        "copilot": {
          "status": "full",
          "targetPaths": [".github/skills"],
          "operations": [
            {
              "type": "generate",
              "generator": "scripts/build-copilot-skills.js",
              "outputRoot": ".github/skills"
            }
          ]
        }
      }
    },
